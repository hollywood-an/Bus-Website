# Server-side only — these are NEVER exposed to the browser (that's the whole point of the proxy).
# Copy to `.env` and fill in. The Anthropic key must never be a VITE_ var or live in the client.

# Required for live chat. Without it, the server returns a graceful error and the client falls
# back to its offline responder.
ANTHROPIC_API_KEY=sk-ant-...

# Production agent model. Default is fast/cheap Haiku; swap to claude-sonnet-4-6 for harder
# multi-step planning. Develop against claude-opus-4-8 if you want.
AGENT_MODEL=claude-haiku-4-5

# Port the proxy listens on (the Vite client dev-proxies /api here).
PORT=8787

# CORS allow-list — lock this to the client origin (the deployed origin in production).
ALLOWED_ORIGIN=http://localhost:5173
